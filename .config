# Minimal config for Redmi AX3000 (IPQ5000/qualcommax/ipq50xx)
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq50xx=y
CONFIG_TARGET_qualcommax_ipq50xx_DEVICE_xiaomi_ax6000=y
CONFIG_TARGET_ROOTFS_PARTSIZE=1600
CONFIG_TARGET_IMAGES_GZIP=y
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-lib-ipkg=y
CONFIG_PACKAGE_luci-app-openclash=y
CONFIG_PACKAGE_luci-app-argon-theme=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
